{
  "name": "auto-register-bywebui",
  "private": true,
  "type": "module",
  "scripts": {
    "build:dev": "node ./scripts/build-extension.mjs --mode=dev",
    "build": "node ./scripts/build-extension.mjs --mode=release",
    "build:release": "node ./scripts/build-extension.mjs --mode=release",
    "build:obfuscate": "node ./scripts/build-extension.mjs --mode=release --obfuscate",
    "package:crx": "node ./scripts/package-crx.mjs",
    "build:crx": "npm run build && npm run package:crx --"
  },
  "dependencies": {
    "clean-css": "^5.3.3",
    "crx3": "^2.0.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.2",
    "html-minifier-terser": "^7.2.0",
    "javascript-obfuscator": "^4.1.1",
    "terser": "^5.39.0"
  }
}
